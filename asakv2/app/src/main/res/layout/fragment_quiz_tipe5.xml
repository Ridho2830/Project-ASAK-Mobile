<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Label Cocokkan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cocokkan!"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_label_rounded"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- Aksara Images + Answer Slots -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="12dp">

            <!-- Column 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="#EEEEEE"
                    app:cardElevation="2dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/colorPrimary">

                    <ImageView
                        android:id="@+id/ivAksara1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:contentDescription="Aksara 1"/>

                </com.google.android.material.card.MaterialCardView>

                <!-- Answer Slot 1 -->
                <TextView
                    android:id="@+id/tvSlot1"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:text="..."
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:background="#DDDDDD"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <!-- Column 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="#EEEEEE"
                    app:cardElevation="2dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/colorPrimary">

                    <ImageView
                        android:id="@+id/ivAksara2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:contentDescription="Aksara 2"/>

                </com.google.android.material.card.MaterialCardView>

                <!-- Answer Slot 2 -->
                <TextView
                    android:id="@+id/tvSlot2"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:text="..."
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:background="#DDDDDD"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </GridLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Answer Options (placeholder slots, hanya reservasi posisi/ruang) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnOpt1"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                android:text="Ha"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"/>

            <Button
                android:id="@+id/btnOpt2"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                android:text="Na"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#CE93D8"/>

            <Button
                android:id="@+id/btnOpt3"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                android:text="Ca"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#29B6F6"/>

            <Button
                android:id="@+id/btnOpt4"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                android:text="Ra"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#AB47BC"/>

        </GridLayout>

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Next ❯"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="@color/colorPrimary"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"/>

    </LinearLayout>

    <!-- Layer paling atas, khusus buat nampung tombol yang sedang/sudah di-drag -->
    <FrameLayout
        android:id="@+id/dragOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"/>

</FrameLayout>