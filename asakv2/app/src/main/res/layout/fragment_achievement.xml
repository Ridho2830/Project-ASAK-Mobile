<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app_light">

    <!-- Sort bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnSortDefault"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Default"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginEnd="3dp"/>

        <ImageView
            android:id="@+id/ivSortArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_down_float"
            android:visibility="invisible"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnSortAz"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="A-Z"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:backgroundTint="#009688"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnSortProgress"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Progress"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/gold_accent"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnSortUnlock"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Unlock"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/green_success"/>

    </LinearLayout>

    <!-- 4 Slot showcase -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvShowcase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="@color/white"
        android:nestedScrollingEnabled="false"/>

    <!-- Tombol Edit -->
    <Button
        android:id="@+id/btnEdit"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:text="✏ Edit"
        android:backgroundTint="@color/gold_accent"
        android:textColor="@color/white"
        android:layout_marginVertical="6dp"/>

    <!-- Total achievement -->
    <TextView
        android:id="@+id/tvTotalAchievement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Achievement: 25"
        android:textColor="@color/gray_dark"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textStyle="bold"
        android:textSize="13sp"/>

    <!-- Grid 25 achievement -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAchievements"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>