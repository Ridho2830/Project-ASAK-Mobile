<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Asakv2" parent="Theme.Material3.Light.NoActionBar">
        <!-- Warna utama (aksen) menggunakan warna logo ASAK (Emas) agar menggantikan ungu -->
        <item name="colorPrimary">@color/asak</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Sentuhan warna emas untuk elemen sekunder -->
        <item name="colorSecondary">@color/asak</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/asak</item>
        <item name="colorOnTertiary">@color/white</item>
        
        <item name="colorPrimaryContainer">@color/asak</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondaryContainer">@color/asak</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Background dan Surface putih (clean look) -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">#F5F5F5</item>
        <item name="colorOnSurfaceVariant">#666666</item>
    </style>

    <style name="Theme.Asakv2" parent="Base.Theme.Asakv2" />

    <style name="circleImageView">
        <item name="cornerSize">50%</item>
    </style>
</resources>