<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Emoji besar sendiri -->
    <TextView
        android:id="@+id/tvResultEmoji"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="80sp"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"/>

    <!-- Judul teks bold besar -->
    <TextView
        android:id="@+id/tvResultTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lulus!"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="6dp"/>

    <!-- Subtitle kecil center -->
    <TextView
        android:id="@+id/tvResultSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kerja bagus! Terus semangat belajar."
        android:textSize="13sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Stats Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Akurasi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎯 Akurasi"
                    android:textColor="#555555"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/tvAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75% (3/4 benar)"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginBottom="14dp"/>

            <!-- Total EXP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⭐ Total EXP"
                    android:textColor="#555555"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/tvTotalExp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+120 EXP"
                    android:textColor="@color/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginBottom="14dp"/>

            <!-- Streak Terbaik -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Streak Terbaik"
                    android:textColor="#555555"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/tvMaxStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#E8A020"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginBottom="14dp"/>

            <!-- Pass Status -->
            <TextView
                android:id="@+id/tvPassStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Bagian ini selesai!"
                android:textColor="#2ecc71"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Spacer dorong konten bawah ke bawah -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Banner akhir stage -->
    <LinearLayout
        android:id="@+id/layoutStageComplete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#6C47FF"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStageCompleteEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏅"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvStageCompleteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvStageCompleteText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kamu telah menyelesaikan Stage 1!"
            android:textSize="14sp"
            android:textColor="#E8E0FF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Tombol kembali -->
    <Button
        android:id="@+id/btnBackHome"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Kembali ke Home"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="@color/colorPrimary"/>

</LinearLayout>